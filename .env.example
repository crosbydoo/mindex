# Copy to .env and adjust values:
#   cp .env.example .env

# Admin login password (used by POST /api/login)
ADMIN_PASSWORD=change-me

# Local Docker Postgres (see docker-compose.yml)
POSTGRES_URL=postgresql://mindex:mindex_local_dev@localhost:5432/mindex

# VPS example (API + Postgres on same server, Postgres not exposed publicly):
# POSTGRES_URL=postgresql://mindex:STRONG_PASSWORD@127.0.0.1:5432/mindex
